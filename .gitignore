# ============================================================
#  PRIVATE — real WireGuard test configs in the repo ROOT
#  (hetzner.conf, leventproxmox.conf, turhost.conf — NEVER commit/push)
# ============================================================
/*.conf
/test-configs/
/secrets/
*.key
*_private*
# Only ROOT-level *.conf is ignored, so packaging/**/*.conf and
# samples/*.conf.example stay tracked.

# ---- GeoIP databases (large; shipped/downloaded separately) ----
*.mmdb
*.mmdb.gz

# ---- C/C++ / CMake build output ----
/build/
/build-*/
cmake-build-*/
*.o
*.so
*.a
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
.cache/

# ---- Rust ----
/target/
**/*.rs.bk
Cargo.lock.orig

# ---- Qt / KDE generated ----
*.user
*.qmlc
*.jsc
moc_*.cpp
qrc_*.cpp
ui_*.h

# ---- Editor / OS ----
.vscode/
.idea/
*.swp
*~
.DS_Store
.directory
